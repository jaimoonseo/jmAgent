# AWS Bedrock Configuration
# Choose one: API Key OR IAM credentials
JMAGENT_AWS_BEARER_TOKEN_BEDROCK=
JMAGENT_AWS_ACCESS_KEY_ID=
JMAGENT_AWS_SECRET_ACCESS_KEY=
JMAGENT_AWS_BEDROCK_REGION=us-east-1

# jmAgent Core Configuration
JMAGENT_DEFAULT_MODEL=haiku
JMAGENT_TEMPERATURE=0.2
JMAGENT_MAX_TOKENS=4096
JMAGENT_PROJECT_ROOT=

# Phase 3 Advanced Features
JMAGENT_ENABLE_CACHING=true
JMAGENT_CACHE_TTL=3600
JMAGENT_ENABLE_STREAMING=false
