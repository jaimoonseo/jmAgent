# ─── AWS Bedrock ─────────────────────────────────────────────────────────────
# Option A: Bedrock API Key (ABSK)
AWS_BEARER_TOKEN_BEDROCK=ABSK-...

# Option B: IAM credentials (comment out ABSK above, fill these)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # only if using temporary credentials

AWS_BEDROCK_REGION=us-east-1

# ─── jmAgent API Auth ────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JMAGENT_API_JWT_SECRET_KEY=change-me-to-a-random-secret

# Optional: static API key for simple auth
# JMAGENT_API_API_KEY=your-api-key

# ─── Agent defaults ──────────────────────────────────────────────────────────
JM_DEFAULT_MODEL=haiku
JM_TEMPERATURE=0.2
JM_MAX_TOKENS=4096
